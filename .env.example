# ══════════════════════════════════════════════
# TRACE — Environment Configuration
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════

# ── AI Provider ─────────────────────────────────
# Choose 'claude' (Anthropic — requires API key) or 'gemini' (Google — generous free tier)
# Gemini free tier: ~60 req/min, supports vision (image analysis)
# Get a free Gemini API key at: https://aistudio.google.com/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic (Claude) — only needed if AI_PROVIDER=claude ──
ANTHROPIC_API_KEY=sk-ant-...

# ── API Security ────────────────────────────────
ADMIN_SECRET=
ANALYSE_API_KEY=
SUBSCRIPTION_SECRET=
AUTH_SECRET=
OPS_API_KEY=

# ── HTTP Server ─────────────────────────────────
PORT=3000
ALLOWED_ORIGIN=http://localhost:3000
SSL_KEY_PATH=
SSL_CERT_PATH=
STATIC_CACHE_TTL=60000

# ── Logging ────────────────────────────────────
TRACE_LOGGING=

# ── Database ────────────────────────────────────
TRACE_DB_PATH=
DATABASE_URL=

# ── Payments (Stripe) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_COLLECTOR_PRICE=price_collector_monthly
STRIPE_PROFESSIONAL_PRICE=price_professional_monthly

# ── External Database APIs ─────────────────────
INTERPOL_API_KEY=
ALR_API_KEY=

# ── Cluster / Deployment ──────────────────────
WORKERS=1
