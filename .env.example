# ══════════════════════════════════════════════
# TRACE — Environment Configuration
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════

# ── AI Provider ─────────────────────────────────
# Options:
#   openrouter (RECOMMENDED) — Access OpenAI, Claude, Gemini through one API + credit management
#   claude     — Direct Anthropic Claude (requires ANTHROPIC_API_KEY)
#   gemini     — Google Gemini (generous free tier, get key at https://aistudio.google.com/apikey)
#   auto       — Auto-fallback chain: claude → gemini → openrouter (skips degraded providers)
#
# 🏆 Mode: 'auto' uses Gemini first (free tier), falls back to OpenRouter/Claude
# Options: auto | gemini | openrouter | claude
# Auto-fallback chain: Gemini (free) → OpenRouter → Claude
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── OpenRouter — fallback provider when Gemini fails (set key to enable) ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-nano

# ── Anthropic (Claude) — only needed if AI_PROVIDER=claude ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini — only needed if AI_PROVIDER=gemini ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── API Security ────────────────────────────────
ADMIN_SECRET=
ANALYSE_API_KEY=
SUBSCRIPTION_SECRET=
AUTH_SECRET=
OPS_API_KEY=

# ── HTTP Server ─────────────────────────────────
PORT=3000
ALLOWED_ORIGIN=http://localhost:3000
SSL_KEY_PATH=
SSL_CERT_PATH=
STATIC_CACHE_TTL=60000

# ── Logging ────────────────────────────────────
TRACE_LOGGING=

# ── Database ────────────────────────────────────
TRACE_DB_PATH=
DATABASE_URL=

# ── Payments (Stripe) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_COLLECTOR_PRICE=price_collector_monthly
STRIPE_PROFESSIONAL_PRICE=price_professional_monthly

# ── External Database APIs ─────────────────────
INTERPOL_API_KEY=
ALR_API_KEY=

# ── Cluster / Deployment ──────────────────────
WORKERS=1
