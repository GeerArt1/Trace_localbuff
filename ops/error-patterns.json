  "scripts": {
    "kill_port_3000": "lsof -ti:3000 2>/dev/null | xargs kill -9 2>/dev/null; sleep 1; echo 'Port 3000 freed'",
    "check_env_key": "if [ -z \"$ANTHROPIC_API_KEY\" ]; then echo 'CRITICAL: ANTHROPIC_API_KEY not set'; else echo 'OK: API key configured ('${#ANTHROPIC_API_KEY}' chars)'; fi",
    "retry_connection": "sleep 2; echo 'Connection retry attempted'",
    "check_upstream_health": "curl -s -o /dev/null -w '%{http_code}' https://api.anthropic.com/v1/messages --max-time 5 2>/dev/null || echo 'Upstream unreachable'",
    "prune_local_storage": "echo 'User must clear browser cache manually. Recommendation sent.'",
    "validate_api_response": "echo 'API validation requires manual inspection of latest response'",
    "restore_subscription_backup": "cp .subscriptions.json.bak .subscriptions.json 2>/dev/null && echo 'Backup restored' || echo 'No backup found'",
    "restore_timeline_backup": "cp .timelines.json.bak .timelines.json 2>/dev/null && echo 'Backup restored' || echo 'No backup found'",
    "install_dependencies": "npm install 2>&1",
    "restart_with_more_memory": "echo 'Increase NODE_OPTIONS=--max-old-space-size=1024 and restart'",
    "check_stripe_connectivity": "curl -s -o /dev/null -w '%{http_code}' https://api.stripe.com --max-time 5 || echo 'Stripe unreachable'",
    "clear_rate_limit_cache": "echo 'Rate limit cache cleared on next server restart'",
    "wait_and_retry": "sleep 3; echo 'Retry attempted after 3s delay'",
    "dns_check": "nslookup api.anthropic.com 2>&1 | head -10 || echo 'DNS failed'",
    "check_cors_config": "echo 'ALLOWED_ORIGIN='${ALLOWED_ORIGIN:-not set}",
    "regenerate_license": "echo 'Use admin panel to regenerate license key'",
    "check_stripe_webhook": "echo 'Verify webhook secret matches Stripe Dashboard'",
    "check_disk_space": "df -h / 2>&1 | tail -1",
    "report_invalid_format": "echo 'Supported formats: JPEG, PNG, WebP'",
    "retry_subscription_check": "curl -s /api/verify-subscription --max-time 5 2>/dev/null || echo 'Subscription API unreachable'",
    "unregister_service_worker": "echo 'Use: navigator.serviceWorker.getRegistrations().then(r => r.forEach(r => r.unregister()))'",
    "check_ssl_cert": "echo 'openssl s_client -connect api.anthropic.com:443 -servername api.anthropic.com 2>&1 | openssl x509 -noout -dates'",
    "check_route_handlers": "echo 'Check for missing return statements in route handlers'",
    "check_request_size": "echo 'Max request body size: 10MB'"
  },
